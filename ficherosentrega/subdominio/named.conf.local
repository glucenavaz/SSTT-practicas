zone "nombreorganizacion6535.org." {
	type slave;
	file "/var/cache/bind/db.nombreorganizacion6535.org.zone";
	masters { 192.168.56.102; };
};
zone "subdominio.nombreorganizacion6535.org" {
	type master;
	file "/etc/bind/db.subdominio.zone";
};
