;
; BIND data file for local loopback interface
;
$TTL	604800
$ORIGIN nombreorganizacion6535.org.

@	IN	SOA	servidor.nombreorganizacion6535.org. admin.nombreorganizacion6535.org. (
			      4		; Serial
			 604800		; Refresh
			  86400		; Retry
			2419200		; Expire
			 604800 )	; Negative Cache TTL
;
@	IN	NS	servidor.nombreorganizacion6535.org.
@	IN	NS	servidorclonado.nombreorganizacion6535.org.
@	IN	MX	10	smtp.nombreorganizacion6535.org.

servidor	IN	A	192.168.56.102
servidorclonado	IN	A	192.168.56.103

cliente	IN	A	192.168.56.102
dns1	IN	A	192.168.56.102
web	IN	A	192.168.56.102
www	IN	A	192.168.56.102
pop	IN	A	192.168.56.102
smtp	IN	A	192.168.56.102
dns2	IN	A	192.168.56.102
subdominio	IN	NS	ns1.subdominio.nombreorganizacion6535.org.
ns1.subdominio	IN	A	192.168.56.103
